from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
from reportlab.lib.styles import getSampleStyleSheet

doc = SimpleDocTemplate("design_report.pdf")
styles = getSampleStyleSheet()

content = []

content.append(Paragraph("Experiment Comparison", styles["Heading1"]))
content.append(Spacer(1, 12))

text = """
Two scheduling strategies were tested: FIFO and Optimized. Both used 1000 tasks with 70/30 IO to CPU distribution and 200ms task duration.

FIFO processed tasks in arrival order. This caused CPU inefficiency when large CPU tasks blocked smaller IO tasks.

Optimized scheduling prioritized IO tasks when CPU usage was high and CPU tasks when usage was low.

FIFO results: CPU 89.65%, Workers 5.07, Runtime 39430ms.
Optimized results: CPU 96.45%, Workers 5.46, Runtime 36650ms.

Optimized scheduling improved CPU usage and reduced total runtime.
"""

content.append(Paragraph(text, styles["BodyText"]))

doc.build(content)